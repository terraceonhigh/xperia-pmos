# Firmware for Sony Xperia 10 III (pdx213)
# Source: Sony Open Devices SW_binaries + stock firmware extraction
# See: https://developer.sony.com/open-source/aosp-on-xperia-open-devices
pkgname=firmware-sony-pdx213
pkgver=20260318
pkgrel=0
pkgdesc="Firmware for Sony Xperia 10 III"
subpackages="
	$pkgname-adreno
	$pkgname-adsp
	$pkgname-bluetooth
	$pkgname-cdsp
	$pkgname-hexagonfs
	$pkgname-ipa
	$pkgname-modem
	$pkgname-venus
	$pkgname-wlan
"
url="https://github.com/terraceonhigh/xperia-pmos"
arch="aarch64"
license="proprietary"
makedepends="pil-squasher"
options="!check !strip !archcheck !tracedeps textrels pmb:cross-native"
# TODO: Host firmware blobs on GitHub and set _commit + source URL
# For now, firmware must be manually placed in $builddir
# See README.md for extraction instructions
_commit=""
source=""
builddir="$srcdir"

build() {
	for i in *.mdt; do
		[ -e "$i" ] || continue
		pil-squasher "$(basename "$i" .mdt)".mbn "$i"
	done
}

package() {
	# parent package is empty
	mkdir -p "$pkgdir"
}

adreno() {
	pkgdesc="Sony Xperia 10 III adreno firmware"

	install -Dm644 "$builddir"/a619_gmu.bin -t \
		"$subpkgdir/lib/firmware/qcom/"
	install -Dm644 "$builddir"/a615_zap.mbn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
}

adsp() {
	pkgdesc="Sony Xperia 10 III adsp firmware"

	install -Dm644 "$builddir"/adsp.mbn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	install -Dm644 "$builddir"/adspr.jsn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	install -Dm644 "$builddir"/adsps.jsn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	install -Dm644 "$builddir"/adspua.jsn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
}

bluetooth() {
	pkgdesc="Sony Xperia 10 III bluetooth firmware"

	# WCN3991 BT firmware
	install -Dm644 "$builddir"/crbtfw32.tlv -t \
		"$subpkgdir/lib/firmware/qca/"
	install -Dm644 "$builddir"/crnv32u.bin -t \
		"$subpkgdir/lib/firmware/qca/"
}

cdsp() {
	pkgdesc="Sony Xperia 10 III cdsp firmware"

	install -Dm644 "$builddir"/cdsp.mbn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	install -Dm644 "$builddir"/cdspr.jsn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
}

hexagonfs() {
	pkgdesc="Sony Xperia 10 III hexagonfs files"

	mkdir -p "$subpkgdir"/usr/share/qcom/sm6350/Sony/
	cp -r "$builddir"/hexagonfs/ \
		"$subpkgdir"/usr/share/qcom/sm6350/Sony/pdx213

	find "$subpkgdir/usr/share/qcom/sm6350/Sony/pdx213/" \
		-type f -exec chmod 0644 {} \;
}

ipa() {
	pkgdesc="Sony Xperia 10 III ipa firmware"

	install -Dm644 "$builddir"/lagoon_ipa_fws.mbn \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/ipa_fws.mbn"
}

modem() {
	pkgdesc="Sony Xperia 10 III modem firmware"

	install -Dm644 "$builddir"/modem.mbn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	install -Dm644 "$builddir"/modemr.jsn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	install -Dm644 "$builddir"/modemuw.jsn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
}

venus() {
	pkgdesc="Sony Xperia 10 III venus firmware"

	install -Dm644 "$builddir"/venus.mbn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
}

wlan() {
	pkgdesc="Sony Xperia 10 III wlan firmware"

	install -Dm644 "$builddir"/wlanmdsp.mbn -t \
		"$subpkgdir/lib/firmware/qcom/sm6350/Sony/pdx213/"
	# ath10k board data (from linux-firmware-ath10k, but device-specific
	# board.bin may be needed)
}

sha512sums="
(run 'pmbootstrap checksum firmware-sony-pdx213' to generate)
"
